# Backend API Configuration
# The base URL for the backend API
# This variable is used both for local development and Docker builds

# For local development (npm start):
# REACT_APP_API_BASE_URL=http://localhost:8000

# For production:
REACT_APP_API_BASE_URL=https://admin.bttrades.com

# IMPORTANT: When building Docker image, pass this as build argument:
# docker build --build-arg REACT_APP_API_BASE_URL=https://admin.bttrades.com -t frontend .
# or use docker-compose which will automatically pick it up from .env file
